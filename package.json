{
  "name": "h1b-nl-query-system",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "ui:min": "bash scripts/ui_minimal.sh",
    "fetch:official-data": "python3 scripts/fetch_official_h1b_data.py --max-rows 30000",
    "build:parquet": "python3 scripts/build_parquet_from_official_csv.py",
    "upload:s3:parquet": "bash scripts/upload_parquet_to_s3.sh",
    "create:cloudfront": "bash scripts/create_cloudfront_for_s3.sh",
    "infra:up": "bash scripts/infra_up.sh",
    "infra:down": "bash scripts/infra_down.sh",
    "dev": "npm run dev -w web",
    "build": "npm run build -w web",
    "lint": "npm run lint -w web"
  }
}
